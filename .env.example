# Discord bot basics (required)
DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Business branding (all optional, sensible placeholders shown)
BUSINESS_NAME=Business 1
SECOND_BUSINESS_NAME=Business 2
SECOND_BUSINESS_DOMAIN=business2.example.com
STORE_DOMAIN=business1.example.com
WATERMARK_TEXT=BUSINESS1.EXAMPLE.COM
BUSINESS_NEWS_QUERY=your industry keywords here
SECOND_BUSINESS_NEWS_QUERY=your second industry keywords here

# Owner / notifications
OWNER_DISCORD_USER_ID=
DAILY_SUMMARY_MENTION_IDS=

# Shopify
SHOPIFY_STORE=your-store.myshopify.com
WHATS_NEW_BLOG_ID=

# Netlify
NETLIFY_SITE_ID=

# Local LLM (optional, for the Ollama-backed helpers)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Board file (optional override; defaults to a local board.md next to the bot)
NV_BOARD_PATH=

# Meta (Facebook/Instagram) ads + auto-posting
FB_ACCESS_TOKEN=
FB_AD_ACCOUNT_ID=
FB_PAGE_ID=
IG_USER_ID=
FB_AUTO_POST_LIVE=false

# Email (Gmail app password, not your regular password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_ADDRESS=contact@business1.example.com

# Discord channel/role/category IDs (right-click in Discord with Developer Mode on, "Copy ID")
TODO_CHANNEL_ID=
CONTACT_CHANNEL_ID=
SUPPORT_ROLE_ID=
SHOPIFY_CATEGORY_ID=
ETSY_CATEGORY_ID=
